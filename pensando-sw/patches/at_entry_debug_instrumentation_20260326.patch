         printf("\n");
 }
 
+void
+dump_at_entry(const char *label, uint64_t ah_base_addr, uint32_t ah_id,
+              uint32_t entry_size) {
+    printf("\n========================================\n");
+    printf("=== %s: AT Entry %d ===\n", label, ah_id);
+    printf("Address: 0x%lx, Entry Size: %d bytes\n",
+           ah_base_addr + ah_id * entry_size, entry_size);
+    printf("========================================\n");
+
+    uint8_t buf_0[128];
+    uint8_t buf_128[128];
+    uint64_t at_addr = ah_base_addr + ah_id * entry_size;
+
+    // Read offset +0 (data template) using model_sim API
+    read_mem(at_addr, buf_0, 128);
+    printf("\nOffset +0 (Data Path Header Template - 128 bytes):\n");
+    hexdump(0, buf_0, 128);
+
+    // Read offset +128 (ACK template or metadata?) using model_sim API
+    read_mem(at_addr + 128, buf_128, 128);
+    printf("\nOffset +128 (ACK Path or Metadata? - 128 bytes):\n");
+    hexdump(128, buf_128, 128);
+
+    // Compare first 64 bytes of both sections
+    int diff_count = 0;
+    for (int i = 0; i < 64; i++) {
+        if (buf_0[i] != buf_128[i]) diff_count++;
+    }
+
+    printf("\n--- Analysis ---\n");
+    printf("Bytes differing between +0 and +128 (first 64 bytes): %d/%d\n",
+           diff_count, 64);
+
+    // Check if offset +128 looks like duplicate header template
+    bool ack_has_mac = (buf_128[0] != 0 || buf_128[1] != 0 ||
+                        buf_128[2] != 0 || buf_128[3] != 0);
+    bool same_as_data = (memcmp(buf_0, buf_128, 64) == 0);
+
+    if (same_as_data) {
+        printf("Result: DUPLICATE - Offset +128 is identical copy of +0\n");
+    } else if (ack_has_mac) {
+        printf("Result: DIFFERENT TEMPLATE - Offset +128 has different content\n");
+    } else {
+        printf("Result: METADATA/ZEROS - Offset +128 appears uninitialized\n");
+        printf("  First 4 bytes: 0x%02x 0x%02x 0x%02x 0x%02x\n",
+               buf_128[0], buf_128[1], buf_128[2], buf_128[3]);
+    }
+    printf("========================================\n\n");
+}
